# Agnes — canonical environment variables.
# Loaded with python-dotenv from .env.local at startup.
# This file is committed; .env.local is NEVER committed.

# --- Storage ----------------------------------------------------------------
AGNES_DATA_DIR=./data
AGNES_RUNNERS_ENABLED=anthropic

# --- Anthropic --------------------------------------------------------------
ANTHROPIC_API_KEY=

# --- Swan (Phase 2 / Phase D) ---------------------------------------------
SWAN_CLIENT_ID=
SWAN_CLIENT_SECRET=
SWAN_WEBHOOK_SECRET=
SWAN_PAYMENT_CONTROL_SECRET=
SWAN_PROJECT_ID=
SWAN_BASE_URL=https://api.sandbox.swan.io
SWAN_OAUTH_URL=https://oauth.swan.io/oauth2/token
SWAN_GRAPHQL_URL=https://api.swan.io/sandbox-partner/graphql

# --- External provider webhook secrets (verifier registry) -----------------
STRIPE_WEBHOOK_SECRET=

# --- Cerebras / Pydantic AI optional ---------------------------------------
CEREBRAS_API_KEY=
