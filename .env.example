# Fingent — canonical environment variables.
# Loaded with python-dotenv from .env.local at startup.
# This file is committed; .env.local is NEVER committed.

# --- Storage ----------------------------------------------------------------
FINGENT_DATA_DIR=./data
FINGENT_RUNNERS_ENABLED=anthropic

# --- Anthropic --------------------------------------------------------------
ANTHROPIC_API_KEY=

# --- Swan (Phase 2 / Phase D) ---------------------------------------------
SWAN_CLIENT_ID=
SWAN_CLIENT_SECRET=
SWAN_WEBHOOK_SECRET=
SWAN_PAYMENT_CONTROL_SECRET=
SWAN_PROJECT_ID=
SWAN_BASE_URL=https://api.sandbox.swan.io
SWAN_OAUTH_URL=https://oauth.swan.io/oauth2/token
SWAN_GRAPHQL_URL=https://api.swan.io/sandbox-partner/graphql

# --- External provider webhook secrets (verifier registry) -----------------
STRIPE_WEBHOOK_SECRET=

# --- Cerebras inference (gpt-oss-120b classifier path) ---------------------
# Required when FINGENT_LLM_PROVIDER=cerebras. Get one at https://cloud.cerebras.ai
CEREBRAS_API_KEY=
# Default classifier-runtime selection (anthropic | cerebras). When set to
# cerebras, anomaly_flag, gl_account_classifier, and counterparty_classifier
# route through PydanticAiRunner against api.cerebras.ai/v1.
FINGENT_LLM_PROVIDER=anthropic
# Per-role Cerebras model overrides. Defaults are picked for free-tier key
# access (gpt-oss-120b + llama3.3-70b require Developer tier). Both default
# free-tier models deprecate 2026-05-27 — flip to gpt-oss-120b after upgrade.
FINGENT_CEREBRAS_CLASSIFIER_MODEL=llama3.1-8b
FINGENT_CEREBRAS_ANOMALY_MODEL=qwen-3-235b-a22b-instruct-2507
